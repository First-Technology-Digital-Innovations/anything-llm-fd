# Example environment variables for Voice Chat - Azure Realtime API
# Copy these to your .env.development file and replace with your actual values

# Voice Chat Configuration
VOICE_CHAT_ENABLED=true
AZURE_REALTIME_ENDPOINT=bcp-ai-east-us-2-resource.cognitiveservices.azure.com
AZURE_REALTIME_KEY=your-azure-realtime-api-key
AZURE_REALTIME_MODEL=gpt-realtime
VOICE_CHAT_DEFAULT_VOICE=alloy
VOICE_CHAT_VAD_THRESHOLD=0.5
VOICE_CHAT_SESSION_TIMEOUT=1500000